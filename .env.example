# ══════════════════════════════════════════════════════
# SheicobAnime — Environment Variables Template
# ══════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copy this file to .env (git-ignored)
# 2. Fill in EVERY value before running
# 3. NEVER commit the .env file with real values
# 4. Keep this .env.example updated when adding new vars
# ══════════════════════════════════════════════════════

# ─── API — ASP.NET 8 (/api) ──────────────────────────

# PostgreSQL — Supabase PgBouncer Session mode (used by app + Hangfire)
# Format: Host=HOST;Port=5432;Database=postgres;Username=postgres.XXXX;Password=PASSWORD;Pooling=true;Maximum Pool Size=10
DATABASE_URL=Host=localhost;Database=animeindex;Username=animeindex;Password=devpassword;Pooling=true;Maximum Pool Size=10

# PostgreSQL — Supabase Direct (used ONLY by EF Core migrations, not by app)
# Format: Host=HOST;Port=5432;Database=postgres;Username=postgres;Password=PASSWORD
DATABASE_URL_DIRECT=Host=localhost;Database=animeindex;Username=animeindex;Password=devpassword

# Redis — Upstash REST format (NOT native TCP — HTTP client only in Phase 1)
# Format: rediss://default:TOKEN@HOST.upstash.io:6379
# Local dev: use native format redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Admin API key — any strong random string
# Generate: openssl rand -hex 32
ADMIN_API_KEY=dev-admin-key-change-before-deploy

# Hangfire dashboard basic auth
HANGFIRE_DASHBOARD_PASSWORD=dev-hangfire-password

# Resend — for dead-letter scrape alerts and DMCA emails
# Get free key at: resend.com
RESEND_API_KEY=

# Sentry — error tracking
# Get free DSN at: sentry.io
SENTRY_DSN=

# CORS — comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# Admin email for dead-letter alerts
ADMIN_EMAIL=your@email.com

# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# ─── FRONTEND — Next.js (/web) ───────────────────────

# API base URL — no trailing slash
NEXT_PUBLIC_API_URL=http://localhost:5000

# Auth.js — Postgres (postgres:// format, same DB as API)
# Use Supabase session-mode pooler for prod, direct URL locally
NEXTAUTH_DATABASE_URL=postgresql://animeindex:devpassword@localhost:5432/animeindex

# Auth.js — session signing secret
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth 2.0 (console.cloud.google.com → Credentials)
# Redirect URI: https://sheicobanime.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Discord OAuth (discord.com/developers → Applications → OAuth2)
# Redirect URI: https://sheicobanime.vercel.app/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google AdSense publisher ID
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Apply at: adsense.google.com (need real traffic first)
NEXT_PUBLIC_ADSENSE_ID=

# Comment system provider
# Options: disqus | remark42 | native
NEXT_PUBLIC_COMMENT_PROVIDER=disqus

# Disqus shortname (from disqus.com/admin)
NEXT_PUBLIC_DISQUS_SHORTNAME=

# Remark42 URL (Phase 2 — self-hosted on Hetzner)
# Format: https://comments.yourdomain.com
NEXT_PUBLIC_REMARK42_URL=

# ─── SCRAPER — SeekStreaming (/scraper) ──────────────
SeekStreaming__ApiKey=
SeekStreaming__MaxParallelUploads=6

# ─── SCRAPER — Instagram auto-publishing (optional) ──
# All three values must be set to activate publishing.
# Leave blank to skip Instagram posting entirely.

# Long-lived Instagram User Access Token (expires in 60 days)
# HOW TO GET (Instagram Graph API for Business):
#   1. Create a Facebook App at developers.facebook.com
#   2. Add the "Instagram" product
#   3. Get a short-lived User Access Token from Graph API Explorer
#      (require scopes: instagram_content_publish, instagram_basic)
#   4. Exchange for long-lived token (valid 60 days):
#      GET https://graph.facebook.com/oauth/access_token
#          ?grant_type=fb_exchange_token&client_id=APP_ID
#          &client_secret=APP_SECRET&fb_exchange_token=SHORT_TOKEN
#   5. Re-extend monthly before day 60 (same endpoint with the long-lived token)
Instagram__AccessToken=

# Instagram Business Account numeric user ID
# Found in debug_token response → data.granular_scopes[*].target_ids
# GET https://graph.facebook.com/debug_token?input_token=TOKEN&access_token=APP_ID|APP_SECRET
Instagram__IgUserId=

# Facebook App credentials — used for monthly token re-extension
Instagram__AppId=
Instagram__AppSecret=

# imgbb.com free API key — needed to host generated images (Meta Graph API requires public URL)
# Register at: api.imgbb.com (free, no credit card)
Instagram__ImgBbApiKey=

# Max episodes per carousel post (Instagram hard limit: 10)
Instagram__MaxCarouselItems=10

# ─── GITHUB ACTIONS SECRETS (set in repo Settings) ───
# These are NOT used locally — set as repo secrets in GitHub UI:
#
# RAILWAY_TOKEN              → from railway.app account settings
# RAILWAY_SERVICE_ID         → API service ID from railway.app
# RAILWAY_SCRAPER_SERVICE_ID → Scraper service ID from railway.app
# VERCEL_TOKEN               → from vercel.com account settings
# VERCEL_ORG_ID              → from vercel.com project settings
# VERCEL_PROJECT_ID          → from vercel.com project settings
# SUPABASE_DB_URL_DIRECT     → same as DATABASE_URL_DIRECT above
#
# Instagram (added to scraper-cron.yml):
# INSTAGRAM_ACCESS_TOKEN     → long-lived IG user token (renew every ~50 days)
# INSTAGRAM_IG_USER_ID       → numeric IG Business account ID
# IMGBB_API_KEY              → imgbb.com API key
