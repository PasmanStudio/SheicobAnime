# ══════════════════════════════════════════════════════
# SheicobAnime — Frontend Environment Variables
# ══════════════════════════════════════════════════════
# Copy to .env.local for local development

# ─── Next.js Public Vars ─────────────────────────────

# Canonical site URL (no trailing slash) — used in share links, sitemap, OG tags.
# UNICA fuente de verdad del dominio (junto a wrangler.jsonc vars para runtime).
NEXT_PUBLIC_SITE_URL=https://sheicobanime.sheicob.workers.dev

# API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Ads (Adsterra) ─────────────────────────────────
# Provider: adsterra | propellerads | stub
NEXT_PUBLIC_AD_PROVIDER=stub

# Adsterra — Popunder (global, fires once per session)
NEXT_PUBLIC_ADSTERRA_POPUNDER_SCRIPT=

# Adsterra — Social Bar (global, notification-style)
NEXT_PUBLIC_ADSTERRA_SOCIALBAR_SCRIPT=

# Adsterra — Native Banner (shared across all AdSlot placements)
NEXT_PUBLIC_ADSTERRA_NATIVE_SCRIPT=
NEXT_PUBLIC_ADSTERRA_NATIVE_HASH=

# Popunder — cooldown propio en ms (además del cap del panel de Adsterra).
# Default 4 h. Subir si querés menos pops, bajar para más ingresos.
NEXT_PUBLIC_POPUNDER_COOLDOWN_MS=

# ─── Analytics (Cloudflare Web Analytics) ───────────
# Token público del beacon. Cloudflare Dashboard → Web Analytics → Add a site.
# Cookieless, sin consentimiento. Vacío = sin analytics.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ─── SEO (Google Search Console) ────────────────────
# Token del meta tag google-site-verification. Search Console → Añadir
# propiedad → "Prefijo de URL" → método "Etiqueta HTML": copiar SOLO el
# content="..." del tag. Vacío = el tag no se renderiza.
# En prod se define como Repository Variable (web.yml).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Donaciones ─────────────────────────────────────
# Cafecito (Argentina, cobra en ARS) — https://cafecito.app/TU_USUARIO
NEXT_PUBLIC_CAFECITO_URL=
# Ko-fi (donantes del exterior, USD) — https://ko-fi.com/TU_USUARIO
NEXT_PUBLIC_KOFI_URL=

# ─── Ads (ExoClick VAST preroll) ────────────────────
# Full VAST tag URL (preferred — wins over zone id if both are set)
NEXT_PUBLIC_EXOCLICK_VAST_URL=https://s.magsrv.com/v1/vast.php?idzone=5904192
# Raw zone id (used if VAST_URL is empty — we build the URL from it)
NEXT_PUBLIC_EXOCLICK_VAST_ZONE_ID=5904192

# ─── Community ──────────────────────────────────────
# Discord server invite URL (shown in nav; leave empty to hide the button)
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/TU_INVITE

# Comment provider: disqus | remark42 | native
NEXT_PUBLIC_COMMENT_PROVIDER=disqus

# Disqus shortname (Phase 6)
NEXT_PUBLIC_DISQUS_SHORTNAME=

# Remark42 URL (Phase 6 — only if COMMENT_PROVIDER=remark42)
NEXT_PUBLIC_REMARK42_URL=

# ─── Auth.js v5 (NextAuth) ──────────────────────────
# Postgres connection string (postgres:// format) — same DB as the API
# Use Supabase session-mode pooler URL for Vercel, or direct URL locally
# Format: postgresql://user:pass@host:port/dbname
NEXTAUTH_DATABASE_URL=postgresql://animeindex:devpassword@localhost:5432/animeindex

# Random 32-char secret for session signing
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0 Client IDs)
# Redirect URI: https://sheicobanime.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Discord OAuth (discord.com/developers → Applications → OAuth2)
# Redirect URI: https://sheicobanime.vercel.app/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ─── Sentry (Phase 12) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# CI-only: source map upload (not needed locally)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ─── Notificaciones push (doc 3 fase 3) ─────────────
# Clave PUBLICA del par VAPID — la privada NO va aca: es secret de GitHub
# Actions (VAPID_PRIVATE_KEY) para scripts/notifications/notify-new-episodes.mjs.
# Generar el par con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
