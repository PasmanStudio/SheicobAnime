{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning",
        "Microsoft.Playwright": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "Hangfire": {
    "SchedulerCron": "0 2 * * *"
  },
  "Source1": {
    "DelayMs": 2500,
    "MaxPages": 180
  },
  "Source2": {
    "DelayMs": 2000,
    "DiscoveryDelayMs": 700,
    "MaxPages": 200
  },
  "SeekStreaming": {
    "TranscodeTimeoutMinutes": 8,
    "TranscodeTimeoutCapMinutes": 12
  }
}
