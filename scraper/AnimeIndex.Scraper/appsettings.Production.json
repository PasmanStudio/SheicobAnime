{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning",
        "Microsoft.Playwright": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "Hangfire": {
    "SchedulerCron": "0 * * * *",
    "Source2Cron": "0 */2 * * *"
  },
  "Source1": {
    "DelayMs": 2500,
    "MaxPages": 180
  },
  "Source2": {
    "DelayMs": 2000,
    "MaxPages": 100
  }
}
